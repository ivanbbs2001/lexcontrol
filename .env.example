# ─────────────────────────────────────────────────────────────
#  LexControl — Variáveis de ambiente
#  Copie este arquivo para .env e preencha com seus valores.
# ─────────────────────────────────────────────────────────────

# Firebase — obtidos no Console do Firebase > Configurações do Projeto
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ID do escritório — todos os dispositivos com o mesmo ID compartilham os dados.
# Use qualquer string única, ex: nome-do-escritorio-2024
VITE_WORKSPACE_ID=meu-escritorio

# Chave da API Anthropic — para análise de contratos com IA
VITE_ANTHROPIC_API_KEY=sk-ant-...
